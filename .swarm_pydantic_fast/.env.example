# LLM API Keys
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here
GEMINI_API_KEY=your-gemini-key

# Swarm mode: "hitl" (Human-in-the-Loop) or "auto" (Autonomous)
SWARN_MODE=hitl

# Model assignments per agent (optional, defaults used if empty)
# Format: provider:model-id
SWARN_MODEL_M0=openai:gpt-4o-mini
SWARN_MODEL_M1=openai:gpt-4o
SWARN_MODEL_M2=openai:gpt-4o
SWARN_MODEL_M3=openai:o3-mini
SWARN_MODEL_M4=openai:gpt-4o-mini
SWARN_MODEL_M5=anthropic:claude-sonnet-4-20250514
SWARN_MODEL_M6=openai:gpt-4o-mini
SWARN_MODEL_ORCHESTRATOR=openai:gpt-4o-mini

# Project root (defaults to current directory)
SWARN_PROJECT_ROOT=
